5.//Print hollow square

#include<iostream>
using namespace std;
int main(){
    
for(int i=1;i<=5;i++){
    for(int j=1;j<=5;j++){
        
        cout<<" ";
        if(i==1||i==5||j==1||j==5){
            cout<<"*";
        }else{
            cout<<" ";
        }
    }
    cout<<"\n";

}
}

6.//Print mirror of right angle triangle

#include<iostream>
using namespace std;
int main(){
 
for(int i=1;i<=5;i++){
    for(int j=5-i;j>=1;j--){
        cout<<" ";
    }
    for(int k=1;k<=i;k++){
        
        cout<< "*";
        
    }
    cout<<"\n";

}
}

7.//Print pyramid

