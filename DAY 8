1.5//Hybrid inheritance

#include<iostream>
using namespace std;
class A{
    public:
    void print(){
     cout<<"Hi"<<"\n";
    }
};
class B:virtual public A{
};
class C:virtual public A{
};
class D:public B, public C{
    
};
int main(){
   D obj1;
   obj1.print();
}

2.//Encapsulation

#include<iostream>
using namespace std;
class BankAccount{
    private:
    int bankBalance;
    public:
   void setBalance(int amount){
       if(amount>=0){
           bankBalance=amount;
       }else{
           cout<<"enter a valid amount";
       }
    }
   int getBalance(){
        return bankBalance;
    }
};
int main(){
    BankAccount obj1;
    obj1.setBalance(5000);
    cout<<obj1.getBalance();
}

