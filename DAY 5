5.//Function overloading

#include<iostream>
using namespace std;
int add(int a,int b){
    return a+b;
    
}
int add(int a,int b,int c){
    return a+b+c;
}
float add(float a,float b,float c,float d){
    return a+b+c+d;
}
double add(double a,double b,double c){
    return a+b+c;
}
int main(){
    cout<<add(5,2)<<"\n";
    cout<<add(5,2,3)<<"\n";
    cout<<add(5.0,2.3,4.5,5.6)<<"\n";
    cout<<add(6.5,7.4,4.3);
}

