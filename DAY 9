//program 1 function overloading same function name and paramteres with different classes:

#include<iostream>
using namespace std;
class Appliance{
    public:
   virtual void turnOn(){
        cout<<"Appliance is getting turn on"<<"\n";
    }
    virtual void work()=0;
};
class Fan:public Appliance{
    void turnOn() override{
        cout<<"Fan blades are moving slowly"<<"\n";
    }
    public:
    void work() override{
        cout<<"once fan starts at full speed it gives cool air"<<"\n";
    }
};
class Toaster:public Appliance{
    public:
    void work() override{
        cout<<"Toaster is heating up the breads"<<"\n";
    }
};
int main(){
    Fan myFan;
    Appliance *kitchenApp;
    kitchenApp=&myFan;
    kitchenApp->turnOn();
    kitchenApp->work();
    Toaster myToast;
    kitchenApp=&myFan;
    kitchenApp->turnOn();
    kitchenApp->work();
}

