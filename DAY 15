1.//reversed array using Stack

#include<iostream>
#include<stack>
using namespace std;
int main(){
    int arr[]={10,20,30,40,50};
    int n=5;
    stack<int> st;
    for(int i=0;i<n;i++){
        st.push(arr[i]);
    }
    for(int i=0;i<n;i++){
        arr[i]=st.top();
        st.pop();
    }
    cout<<"reversed array";
    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }
    return 0;
}

2.//reversed string using stack

class Solution {
public:
    void reverseString(vector<char>& s) {
        stack<char> st;
    for(int i=0;i<s.size();i++){
        st.push(s[i]);
    }
    int i=0;
    while(!st.empty()){
        s[i++]=st.top();
        st.pop();
    }
    }
   };

3.//Valid Parentheses

class Solution {
public:
    bool isValid(string s) {

        stack<char> st;

        for(char ch : s) {
            if(ch == '(' || ch == '{' || ch == '[') {
                st.push(ch);
            }
            else {
                if(st.empty()) {
                    return false;
                }
                if((ch == ')' && st.top() == '(') ||
                   (ch == '}' && st.top() == '{') ||
                   (ch == ']' && st.top() == '[')) {

                    st.pop();
                }
                else {
                    return false;
                }
            }
        }
        return st.empty();
    }
};

4.//Next greater element leetcode

class Solution {
public:
    vector<int> nextGreaterElement(vector<int>& nums1, vector<int>& nums2) {

        stack<int> st;
        unordered_map<int, int> mp;
        for(int i = nums2.size() - 1; i >= 0; i--) {

            while(!st.empty() && st.top() <= nums2[i]) {
                st.pop();
            }

            if(st.empty()) {
                mp[nums2[i]] = -1;
            }
            else {
                mp[nums2[i]] = st.top();
            }

            st.push(nums2[i]);
        }

        vector<int> ans;
        for(int num : nums1) {
            ans.push_back(mp[num]);
        }

        return ans;
    }
};

5.//Next greater element geeks for geeks

#include <iostream>
#include <vector>
#include <stack>
using namespace std;
class Solution{
  public:

vector<int> nextLargerElement(vector<int> &arr) {
    int n=arr.size();
  stack<int> st;
  vector<int> nge(n);
  for(int i=n-1;i>=0;i--){
    while(!st.empty()&& st.top()<=arr[i]){
      st.pop();
    }
    if(st.empty()){
      nge[i]=-1;
    }else{
      nge[i]=st.top();
    }
    st.push(arr[i]);
  }
  return nge;
}
};
int main() {

    Solution obj;

    vector<int> arr = {6, 8, 0, 1, 3};

    vector<int> ans = obj.nextLargerElement(arr);

    for(int x : ans) {
        cout << x << " ";
    }

    return 0;
}




