1.//Right and reverse triangle pattern

#include<iostream>
using namespace std;
int main(){
    int n=5;
    for(int i=1;i<=5;i++){
        for(int j=1;j<=i;j++){
            cout<<"*";
        }
        cout<<" \n";
    }
for(int i=n-1;i>=1;i--){
    for(int j=1;j<=i;j++){
        cout<<"*";
    }
    cout<<" \n";
}
}

