6.//Print factorial of a no using for loop

#include <iostream>
using namespace std;
int main(){
    int n;
    cout<<"enter a no";
    cin>>n;
    int fact=1;
    for(int i=n;i>=1;i--){
        fact=fact*i;
    }
    cout<<fact;
}

7.//Print prime no using for loop

#include <iostream>
using namespace std;
int main(){
    int n;
    cout<<"enter a no";
    cin>>n;
    bool prime=true;
    if(n<2){
        prime=false;
    }else{
    for(int i=2;i<n;i++){
        if(n%i==0){
            prime=false;
            break;
        }
    }
}
if(prime){
    cout<<"prime number";
}else{
    cout<<"not a prime number";
  }
}

