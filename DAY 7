problem3: protected access specifier
  #include <iostream>
using namespace std;

class Parent {
protected:
   int seceretCode = 1234;
};

class child : public Parent{
public:
    void accessLocker(){
        cout << secretCode;
    }
};
int main() {
    child obj1;
    obj1.accessLocker();
}

