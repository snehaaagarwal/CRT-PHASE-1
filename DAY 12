1.//Recursion

#include<iostream>
using namespace std;
void printNumber(int n){
    if(n>5){
        return;
    }
    cout<<n<<" ";
    printNumber(n+1);
}
int main(){
    printNumber(1);
}

2.// Factorial using recursion

#include<iostream>
using namespace std;
int fact(int n){
    if(n==0||n==1){
    return 1;
    }else{
        return n*fact(n-1);
    }
    
}
int main(){
    int n;
    cin>>n;
    cout<<fact(n);
    return 0;
}
