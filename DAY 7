program1:call by value and call by refrence
  #include <iostream>
using namespace std;

void updatebyValue(int a){
    a = 500;
}

void updateByRefrence(int &a){
    a=500;
}

int main(){
    int original = 100;
    updatebyValue(original);
    cout << original << "\n";
    updateByRefrence(original);
    cout << original;

}

