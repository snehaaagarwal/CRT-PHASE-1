3.//Print no 1 to 10 using while loop

#include <iostream>
using namespace std;
int main(){
    int i=1;
    while(i<=10){
        cout<<i<<" ";
        i++;
    }
}

4.//Print no 1 to 10 using do-while loop

#include <iostream>
using namespace std;
int main(){
    int i=1;
    do{
        cout<<i<<" ";
        i++;
    }while(i<=10);
}

